{
  "version": 2,
  "builds": [
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "api/contact.js", "use": "@vercel/node" },
    { "src": "css/*", "use": "@vercel/static" },
    { "src": "js/*", "use": "@vercel/static" },
    { "src": "images/*", "use": "@vercel/static" },
    { "src": "images/**/*", "use": "@vercel/static" },
    { "src": "favicon.ico", "use": "@vercel/static" },
    { "src": "site.webmanifest", "use": "@vercel/static" },
    { "src": "apple-touch-icon.png", "use": "@vercel/static" },
    { "src": "favicon-32x32.png", "use": "@vercel/static" },
    { "src": "favicon-16x16.png", "use": "@vercel/static" },
    { "src": "images/header-bg-3000.jpg", "use": "@vercel/static" },
    { "src": "images/testimonials-bg-3000.jpg", "use": "@vercel/static" },
    { "src": "images/imagen destacada.jpg", "use": "@vercel/static" },
    { "src": "images/Logo.jpg", "use": "@vercel/static" },
    { "src": "images/wheel-1000.jpg", "use": "@vercel/static" },
    { "src": "images/wheel-2000.jpg", "use": "@vercel/static" },
    { "src": "images/wheel-500.jpg", "use": "@vercel/static" },
    { "src": "images/logo.svg", "use": "@vercel/static" },
    { "src": "images/sample-image.jpg", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/contact", "dest": "/api/contact" },
    { "src": "/(.*)", "dest": "/$1" },
    {
      "src": "/(.*)",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    }
  ]
}

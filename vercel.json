{
  "version": 2,
  "builds": [
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "api/contact.js", "use": "@vercel/node" },
    { "src": "css/*", "use": "@vercel/static" },
    { "src": "js/*", "use": "@vercel/static" },
    { "src": "images/*", "use": "@vercel/static" },
    { "src": "favicon.ico", "use": "@vercel/static" },
    { "src": "site.webmanifest", "use": "@vercel/static" },
    { "src": "apple-touch-icon.png", "use": "@vercel/static" },
    { "src": "favicon-32x32.png", "use": "@vercel/static" },
    { "src": "favicon-16x16.png", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/contact", "dest": "/api/contact" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}

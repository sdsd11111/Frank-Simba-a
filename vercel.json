{
  "version": 2,
  "builds": [
    { "src": "*.{html,ico,webmanifest}", "use": "@vercel/static" },
    { "src": "sitemap.xml", "use": "@vercel/static" },
    { "src": "css/*.css", "use": "@vercel/static" },
    { "src": "js/**/*.js", "use": "@vercel/static" },
    { "src": "images/**/*.{jpg,jpeg,png,svg,webp}", "use": "@vercel/static" },
    { "src": "blog/**/*.html", "use": "@vercel/static" },
    { "src": "*.{css,js,png,jpg,jpeg,svg,webp,ico,webmanifest}", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/(.*\\.(js|css|png|jpg|jpeg|svg|webp|ico|webmanifest|xml|json|txt))$", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/pago.html" }
  ]
}

{
  "version": 2,
  "builds": [
    { "src": "*.{html,ico,webmanifest}", "use": "@vercel/static" },
    { "src": "css/*.css", "use": "@vercel/static" },
    { "src": "js/**/*.js", "use": "@vercel/static" },
    { "src": "images/**/*.{jpg,jpeg,png,svg}", "use": "@vercel/static" },
    { "src": "*.{css,js,png,jpg,jpeg,svg}", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/(.*.js|css|png|jpg|jpeg|svg|ico|webmanifest)", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
